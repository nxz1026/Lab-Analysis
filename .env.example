# Lab-Analysis 环境变量配置示例
# 复制此文件为 .env 并填写您的实际值

# ===== 必需的 API 密钥 =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ===== 可选的 API 密钥 =====
OPENROUTER_API_KEY=sk-your-openrouter-api-key-here

# ===== 目录配置 =====
WORK_ROOT=/root/workplace/
ORIGIN_DATA_DIR=/root/workplace/raw/Origin_data

# ===== 其他配置 =====
# ANALYSIS_TS=20260507_143000

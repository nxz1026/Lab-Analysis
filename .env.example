# Lab-Analysis 环境变量配置示例
# 复制此文件为 .env 并填写您的实际值

# ===== 必需的 API 密钥 =====
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here

# ===== 可选的 API 密钥 =====
OPENROUTER_API_KEY=sk-your-openrouter-api-key-here
# 智谱 AI（GLM-4V）用于检验报告图片 OCR；留空则跳过该能力
ZHIPU_API_KEY=your-zhipu-api-key-here

# ===== 脱敏主密钥（患者身份证号 AES-GCM 加密用）=====
# 留空时首次运行会自动生成 .hermes/master.key（已 gitignore，请妥善备份）
# 生产环境强烈建议通过此环境变量注入，避免密钥落盘
# 生成方法: python -c "import secrets,base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
LAB_DEID_KEY=

# ===== 目录配置 =====
WIKI_ROOT=e:\\wiki
ORIGIN_DATA_DIR=e:\\wiki\\raw\\Origin_data

# ===== 其他配置 =====
# ANALYSIS_TS=20260507_143000
